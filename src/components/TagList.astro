---
import { slugify } from "../utils/helpers";

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="tag-list">
  {tags.map((tag) => (
    <a href={`/tags/${slugify(tag)}`} class="tag">{tag}</a>
  ))}
</div>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    background: var(--tag-bg);
    color: var(--tag-text);
    padding: var(--space-1) var(--space-3);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;

    &:hover {
      opacity: 0.8;
    }
  }
</style>
