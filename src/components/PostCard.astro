---
import FormattedDate from "./FormattedDate.astro";
import TagList from "./TagList.astro";
import { slugify } from "../utils/helpers";

interface Props {
  title: string;
  slug: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
}

const { title, slug, description, pubDate, category, tags } = Astro.props;
---

<article class="post-card">
  <div class="post-card__meta">
    <FormattedDate date={pubDate} />
    <span class="post-card__sep">&middot;</span>
    <a href={`/categories/${slugify(category)}`} class="post-card__category">{category}</a>
  </div>
  <h2 class="post-card__title">
    <a href={`/blog/${slug}`}>{title}</a>
  </h2>
  <p class="post-card__desc">{description}</p>
  <TagList tags={tags} />
</article>

<style>
  .post-card {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--border);
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
  }

  .post-card__sep {
    color: var(--border);
  }

  .post-card__category {
    color: var(--accent);
    font-weight: 500;
  }

  .post-card__title {
    font-size: 1.35rem;
    margin-bottom: var(--space-2);
    line-height: 1.3;

    a {
      color: var(--accent);

      &:hover {
        color: var(--accent-hover);
      }
    }
  }

  .post-card__desc {
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
    line-height: 1.6;
  }
</style>
