---
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="header">
  <nav class="container header__nav">
    <a href="/" class="header__logo">CS Blog</a>

    <div class="header__actions">
      <ThemeToggle />
      <button id="menu-toggle" type="button" class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div id="nav-menu" class="header__links">
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/categories">Categories</a>
      <a href="/tags">Tags</a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("nav-menu")!;

  toggle.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    menu.classList.toggle("open");
  });
</script>

<style lang="scss">
  @use "../styles/mixins" as *;

  .header {
    border-bottom: 1px solid var(--border);
    padding: var(--space-4) 0;
  }

  .header__nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .header__logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin-right: auto;

    &:hover {
      color: var(--accent);
    }
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .menu-toggle {
    display: flex;
    align-items: center;
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    padding: var(--space-1);

    .icon-close {
      display: none;
    }

    &[aria-expanded="true"] {
      .icon-menu {
        display: none;
      }
      .icon-close {
        display: block;
      }
    }

    @include respond-to("md") {
      display: none;
    }
  }

  .header__links {
    display: none;
    width: 100%;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-3);

    &.open {
      display: flex;
    }

    a {
      color: var(--text-secondary);
      font-size: 0.95rem;
      padding: var(--space-2) 0;

      &:hover {
        color: var(--accent);
      }
    }

    @include respond-to("md") {
      display: flex;
      width: auto;
      flex-direction: row;
      align-items: center;
      gap: var(--space-4);
      padding-top: 0;

      a {
        font-size: 0.9rem;
        padding: 0;
      }
    }
  }
</style>
